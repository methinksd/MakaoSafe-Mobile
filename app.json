{
  "expo": {
    "name": "MakaoSafe",
    "slug": "makaosafe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "makaosafe",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C3CE1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.makaosafe.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow MakaoSafe to access your photos to upload property images.",
        "NSCameraUsageDescription": "Allow MakaoSafe to take photos of your property.",
        "NSLocationWhenInUseUsageDescription": "MakaoSafe uses your location to find nearby properties.",
        "NSLocationAlwaysUsageDescription": "MakaoSafe uses your location to find nearby properties."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C3CE1"
      },
      "package": "com.makaosafe.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MakaoSafe to access your photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MakaoSafe to use your location to find nearby properties."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}