# MakaoSafe — Environment Variables
# Copy this file to .env and edit for your environment.
# .env is gitignored. Never commit real credentials.

# API base URL — defaults to production if not set.
# For local development, replace with your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8080/api
EXPO_PUBLIC_API_URL=https://makaosafe-backend.onrender.com/api
